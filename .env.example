DATABASE_URL=sqlite:///./data/marketing_parser.db
AUTO_CREATE_SCHEMA=false
PARSER_REQUEST_TIMEOUT=20
PARSER_MAX_RETRIES=3
PARSER_POLITE_MODE_ENABLED=true
PARSER_REQUEST_DELAY_MS=900
PARSER_REQUEST_JITTER_MS=700
PARSER_RETRY_BASE_DELAY_MS=1000
PARSER_RATE_LIMIT_COOLDOWN_MS=60000
PARSER_PRODUCT_DETAIL_REQUEST_DELAY_MS=300
PARSER_PRODUCT_DETAIL_CONCURRENCY=4
PARSER_CONCURRENCY=2
PARSER_AUTO_RUN_ENABLED=false
PARSER_AUTO_RUN_INTERVAL_DAYS=5
PARSER_AUTO_RUN_SOURCE_CODE=globus
PARSER_AUTO_RUN_CHECK_INTERVAL_SECONDS=3600
PARSER_AUTO_RUN_STARTUP_DELAY_SECONDS=30
AUTH_ENABLED=true
IDENTITY_SECRET_KEY=dev-change-me-32-byte-secret-key-for-turkuaz-identity
IDENTITY_ALGORITHM=HS256
